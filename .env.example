# Database (hanzoai/sql - PostgreSQL 18 fork)
DATABASE_URL=postgresql://paas:password@localhost:5432/paas

# Cache/Queue (hanzoai/kv - Valkey 8 fork)
KV_URL=redis://localhost:6379

# Auth (hanzo.id - Casdoor IAM)
HANZO_IAM_ISSUER=https://hanzo.id
HANZO_IAM_CLIENT_ID=hanzo-platform-client-id
HANZO_IAM_CLIENT_SECRET=

# Platform
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=dev-secret-change-in-production

# Cloud Providers (optional)
DO_API_TOKEN=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Container Registry
GHCR_TOKEN=
